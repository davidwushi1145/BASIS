# Copy this file to .env and fill in your actual values

# ==================== Model Paths ====================
EMBEDDING_PATH=/data/models/Qwen3-Embedding-0.6B
RERANKER_PATH=/data/models/Qwen3-Reranker-0.6B
NER_MODEL_PATH=/data/models/d4data/biomedical-ner-all

# ==================== Corpus & Cache ====================
CORPUS_FILE=/data/miner/rag_corpus_contextual.jsonl
# VECTOR_CACHE will auto-compute from CORPUS_FILE if not specified

# ==================== Device Configuration ====================
DEVICE=cuda:0

# ==================== API Keys (REQUIRED) ====================
SERPER_API_KEY=your_serper_api_key_here
API_KEY=your_openai_compatible_api_key_here

# ==================== Optional API Configuration ====================
PROXY_URL=http://127.0.0.1:6152
SOLVER_API_BASE=https://chat.intern-ai.org.cn/api/v1
SOLVER_MODEL_NAME=intern-s1-mini
VERIFIER_MODEL_NAME=intern-s1-mini

# ==================== NCBI/PubMed ====================
NCBI_EMAIL=your-email@example.com
NCBI_API_KEY=your_ncbi_api_key# Optional: increases rate limit to 10 req/s
NCBI_TOOL_NAME=SLAgent_RAG

# ==================== MinerU PDF Parsing (Optional) ====================
# MINERU_API_TOKEN=your_mineru_token
MINERU_API_BASE=https://mineru.net/api/v4/extract/task
MINERU_MODEL_VERSION=vlm
MINERU_MAX_POLL_TIME=300
MINERU_POLL_INTERVAL=5

# ==================== PDF Cache ====================
PDF_CACHE_DIR=/tmp/sl_agent/pdf_cache

# ==================== DepMap & External KG ====================
DEPMAP_DATA_DIR=/data/SLbm/data
EXTERNAL_KG_DB_PATH=/data/SLbm/data/kg.db

# ==================== Feature Flags ====================
USE_GRAPH_RAG=true
USE_HYDE=true
USE_AGENTIC_RAG=true
USE_CONTEXT_COMPRESSION=false
USE_DEPMAP_KB=true
USE_EXTERNAL_KG=true
USE_GENE_SYNONYM_EXPANSION=true
USE_BIO_NORMALIZATION=true
USE_STRING_VALIDATION=true
USE_OPENTARGETS_VALIDATION=true

# ==================== Token Budget ====================
MAX_CONTEXT_TOKENS=12000
TOKEN_BUDGET_SYSTEM=1000
TOKEN_BUDGET_EXTERNAL_KG_MAX=1500
TOKEN_BUDGET_KB_MAX=3000
TOKEN_BUDGET_GRAPH_MAX=1500

# ==================== Agentic RAG ====================
AGENTIC_SCORE_THRESHOLD=0.4
AGENTIC_MAX_HOPS=2
AGENTIC_MECHANISTIC_QUERIES=3

# ==================== Logging ====================
LOG_FILE=/data/vllm/raglog/rag_system.log# Optional
LOG_LEVEL=INFO

# ==================== Server Configuration ====================
HOST=0.0.0.0
PORT=16006
WORKERS=4
